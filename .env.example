# Sanity project (safe to expose, NEXT_PUBLIC_*)
NEXT_PUBLIC_SANITY_PROJECT_ID="72k8551o"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-02-01"

# Read token — REQUIRED for live content updates and draft preview.
# Without it, the Live Content API is disabled and the deployed site only
# reflects Sanity changes after a redeploy.
# Create one at https://sanity.io/manage -> project 72k8551o -> API -> Tokens
# (permission: Viewer). Set the SAME value in Vercel -> Settings -> Environment
# Variables for Production, Preview and Development.
SANITY_API_READ_TOKEN=""

# Secret shared with the Sanity GROQ webhook that calls /api/revalidate/tag.
# Pick any strong random string; set the identical value here, in Vercel, and
# in the Sanity webhook's "Secret" field (API -> Webhooks).
SANITY_REVALIDATE_SECRET=""
